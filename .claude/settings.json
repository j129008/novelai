{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "WebFetch",
      "WebSearch",
      "Skill(update-config)",
      "Skill(ship)",
      "Skill(create-pr)",
      "Skill(retro)",
      "Skill(simplify)",
      "Skill(ui-review)",
      "Skill(design-system)",
      "Skill(loop)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(chmod -R 777:*)",
      "Bash(chmod 777:*)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(wget:*)",
      "Bash(eval:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_ID=$(cat /dev/stdin | jq -r '.session_id'); MARKER=\"/tmp/claude-pm-approved-${SESSION_ID}\"; if [ ! -f \"$MARKER\" ]; then printf '{\"decision\":\"block\",\"reason\":\"PM (Steve Jobs) 尚未審核通過。請先呼叫 steve-jobs agent 進行產品審查。收到 SHIP IT 後，執行 touch %s 即可結束。\"}' \"$MARKER\"; fi",
            "timeout": 5,
            "statusMessage": "Checking PM approval..."
          },
          {
            "type": "command",
            "command": "say 'Pipeline 完成，請回來查看結果'",
            "timeout": 10,
            "statusMessage": "Notifying..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
