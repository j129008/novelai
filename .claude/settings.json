{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git stash:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git tag:*)",
      "Bash(python:*)",
      "Bash(pip install:*)",
      "Bash(pip list:*)",
      "Bash(pip freeze:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(uvicorn:*)",
      "Bash(kill:*)",
      "Bash(lsof:*)",
      "Bash(ps:*)",
      "Bash(open:*)",
      "Bash(jq:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Skill(update-config)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- .)",
      "Bash(git restore .)",
      "Bash(chmod -R 777:*)",
      "Bash(chmod 777:*)",
      "Bash(sudo:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(wget:*)",
      "Bash(eval:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SESSION_ID=$(cat /dev/stdin | jq -r '.session_id'); MARKER=\"/tmp/claude-pm-approved-${SESSION_ID}\"; if [ ! -f \"$MARKER\" ]; then printf '{\"decision\":\"block\",\"reason\":\"PM (Steve Jobs) 尚未審核通過。請先呼叫 steve-jobs agent 進行產品審查。收到 SHIP IT 後，執行 touch %s 即可結束。\"}' \"$MARKER\"; fi",
            "timeout": 5,
            "statusMessage": "Checking PM approval..."
          }
        ]
      }
    ]
  }
}
